# ── Anthropic ──────────────────────────────────────────────
ANTHROPIC_API_KEY=your_api_key_here

# ── Telegram ───────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ── Server ─────────────────────────────────────────────────
PORT=8000
HOST=0.0.0.0

# ── Upwork RSS (no auth needed) ────────────────────────────
# Build your search URL from Upwork's RSS feed
# Example: https://www.upwork.com/ab/feed/jobs/rss?q=gohighlevel+automation&sort=recency
UPWORK_RSS_URL=https://www.upwork.com/ab/feed/jobs/rss?q=your_search_terms_here
